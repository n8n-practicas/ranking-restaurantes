    {
      "parameters": {
        "jsCode": "const restaurantes = [1, 2, 3, 4, 5, 6, 7];\nconst updates = restaurantes.map(id => {\n  const base = id <= 3 ? 60 : id <= 5 ? 40 : 25;\n  const variacion = Math.floor(Math.random() * 30) - 10;\n  const pedidosNuevos = Math.max(10, base + variacion);\n  return { id, pedidosNuevos };\n});\nreturn updates.map(u => ({ json: u }));"
      },
