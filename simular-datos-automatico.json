    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO tendencias (restaurante_id, semana, pedidos, ingresos_cop)\nSELECT \n  id AS restaurante_id,\n  CURRENT_DATE AS semana,\n  CASE \n    WHEN id <= 2 THEN FLOOR(300 + RANDOM() * 100)::int\n    WHEN id <= 4 THEN FLOOR(200 + RANDOM() * 80)::int\n    ELSE FLOOR(130 + RANDOM() * 60)::int\n  END AS pedidos,\n  CASE \n    WHEN id <= 2 THEN FLOOR((300 + RANDOM() * 100) * 35000)::bigint\n    WHEN id <= 4 THEN FLOOR((200 + RANDOM() * 80) * 35000)::bigint\n    ELSE FLOOR((130 + RANDOM() * 60) * 35000)::bigint\n  END AS ingresos_cop\nFROM restaurantes\nWHERE activo = TRUE\nON CONFLICT (restaurante_id, semana) DO UPDATE\n  SET pedidos = EXCLUDED.pedidos,\n      ingresos_cop = EXCLUDED.ingresos_cop;",
        "options": {}
